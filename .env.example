# Service listening port (provides both MCP protocol and static file serving)
PORT=8989

# REST API listening port (exposes /api/GenerateEchartsPage and /docs)
API_PORT=8990

# Service public URL (used to generate chart page links)
PUBLIC_URL=http://localhost:8989

# Log level (optional values: trace, debug, info, warn, error, fatal, panic)
LOG_LEVEL=info

# Static file storage directory
STATIC_DIR=static
